{
  "name": "@itradingai/aiwiki",
  "version": "0.2.7",
  "type": "module",
  "description": "Agent-first local knowledge production CLI for a single knowledge base.",
  "license": "MIT",
  "keywords": [
    "aiwiki",
    "agent",
    "knowledge-base",
    "obsidian",
    "dataview"
  ],
  "homepage": "https://maxking.cc/aiwiki",
  "bugs": {
    "url": "https://github.com/iTradingAI/aiwiki/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iTradingAI/aiwiki.git"
  },
  "files": [
    "dist/src",
    "README.md",
    "docs/*.md",
    "docs/architecture.svg",
    "skill"
  ],
  "bin": {
    "aiwiki": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test \"dist/tests/*.test.js\"",
    "check": "npm run test",
    "release:check": "npm test && node scripts/release-check.mjs",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
